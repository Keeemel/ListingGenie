# ── Gemini ────────────────────────────────────────────────────────────────────
# Free tier — https://aistudio.google.com/app/apikey
# Without this key, on-page audit (score + issues) still works fully.
# Keyword gap analysis + listing optimization require the key.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com → Settings → API
# Run the SQL in README (or docs) to create the profiles table + trigger.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Only used server-side in the webhook

# ── Stripe ────────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Dashboard → Developers → Webhooks → Add endpoint → copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard → Products → create two one-time products, copy their Price IDs:
#   Starter  4.99 EUR → 15 optimizations
STRIPE_PRICE_STARTER=price_...
#   Value    9.99 EUR → 40 optimizations
STRIPE_PRICE_VALUE=price_...
